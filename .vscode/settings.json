{
  "java.test.defaultConfig": "Movie Service Tests",

  "java.test.config": [
    {
      "name": "Movie Service Tests",
      "testKind": "junit",
      "workingDirectory": "${workspaceFolder}/backend/movie-service",
      "preLaunchTask": "gradle-ensure-podman"
    }
  ],

  "java.configuration.updateBuildConfiguration": "automatic",
  "java.import.gradle.enabled": true,
  "java.import.gradle.wrapper.enabled": true,
  "java.import.gradle.java.home": "/home/liviu/.sdkman/candidates/java/current",

  "java.jdt.ls.java.home": "/home/liviu/.sdkman/candidates/java/current",
  "java.configuration.runtimes": [
    {
      "name": "JavaSE-25",
      "path": "/home/liviu/.sdkman/candidates/java/current",
      "default": true
    }
  ],

  "java.test.editor.enableShortcuts": true,
  "java.test.log.level": "info",
  "java.format.settings.url": ".vscode/java-formatter.xml",
  "java.compile.nullAnalysis.mode": "disabled",
  "java.preferences.compiler.pb.deprecation": "ignore",

  "files.watcherExclude": {
    "**/.gradle/**": true,
    "**/build/**": true,
    "**/bin/**": true
  },
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true,
    "**/.gradle": true,
    "**/.idea": true,
    "**/.sonarlint": true,
    "**/.claude": true,
    "**/.cursor": true,
    "**/build": true,
    "**/bin": true,
    "**/node_modules": true,
    "**/.git": true,
    "**/dist": true,
    "**/out": true,
    "**/coverage": true,
    "**/.DS_Store": true,
    "**/.github": true,
    "**/.vscode": true
  },
  "java.autobuild.enabled": true
}
