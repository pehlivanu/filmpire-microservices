{
  "java.test.defaultConfig": "Movie Service Tests",

  "java.test.config": [
    {
      "name": "Movie Service Tests",
      "testKind": "junit",
      "workingDirectory": "${workspaceFolder}/backend/movie-service",
      "preLaunchTask": "gradle-ensure-podman"
    }
  ],

  "java.configuration.updateBuildConfiguration": "automatic",
  "java.import.gradle.enabled": true,
  "java.import.gradle.wrapper.enabled": true,
  "java.import.gradle.java.home": "/home/liviu/.sdkman/candidates/java/current",

  "java.jdt.ls.java.home": "/home/liviu/.sdkman/candidates/java/current",
  "java.configuration.runtimes": [
    {
      "name": "JavaSE-25",
      "path": "/home/liviu/.sdkman/candidates/java/current",
      "default": true
    }
  ],

  "java.test.editor.enableShortcuts": true,
  "java.test.log.level": "info",
  "java.format.settings.url": ".vscode/java-formatter.xml",
  "java.compile.nullAnalysis.mode": "disabled",
  "java.preferences.compiler.pb.deprecation": "ignore",

  "files.watcherExclude": {
    "**/.gradle/**": true,
    "**/build/**": true,
    "**/bin/**": true
  },
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true,
    "**/.gradle": true,
    "**/.idea": true,
    "**/.sonarlint": true,
    "**/.claude": true,
    "**/.cursor": true,
    "**/build": true,
    "**/bin": true,
    "**/node_modules": true,
    "**/.git": true,
    "**/dist": true,
    "**/out": true,
    "**/coverage": true,
    "**/.DS_Store": true,
    "**/.github": true,
    "**/.vscode": true
  },
  "java.autobuild.enabled": true,

  // --- SonarQube for IDE (SonarLint) — see Sonar results inline (#20) ---
  // The project BINDING lives in .sonarlint/connectedMode.json (committed, so
  // everyone binds to the same SonarQube project). The server CONNECTION and
  // its token are deliberately NOT here — they are machine-specific and must
  // never be committed. Add them once in your IDE's *user* settings:
  //
  //   "sonarlint.connectedMode.connections.sonarqube": [
  //     { "connectionId": "filmpire-local", "serverUrl": "http://localhost:9010" }
  //   ]
  //
  // ...then run "SonarQube for IDE: Connect to SonarQube (Server)" and paste a
  // token, which is stored in the OS keychain.
  //
  // Show ALL issues, not just those on new code. Flip to true to adopt
  // clean-as-you-code (matching the server's New Code quality gate) once the
  // existing findings are triaged.
  "sonarlint.focusOnNewCode": false,
  // Tell SonarLint which files are tests, so test-only rule relaxations apply
  // and main-code rules aren't reported against test sources.
  "sonarlint.testFilePattern": "**/src/test/**/*"
}
