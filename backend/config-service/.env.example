# Environment Variables Template for Config Service
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# PostgreSQL Database
POSTGRES_URL=jdbc:postgresql://localhost:5432/filmpire
POSTGRES_USERNAME=admin
POSTGRES_PASSWORD=your-secure-password-here

# MongoDB Database
MONGODB_URI=mongodb://admin:admin123@localhost:27017/filmpire?authSource=admin
MONGODB_DATABASE=filmpire

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO Object Storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=filmpire-media

# JWT Configuration (REQUIRED for user-service)
# Generate a secure random string (minimum 512 bits / 64 characters)
JWT_SECRET=change-this-to-a-secure-random-string-min-64-chars-for-production-use
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# OpenAI API (for AI Service - when enabled)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Eureka Server
EUREKA_SERVER_URL=http://localhost:8761/eureka/

# Config Server Encryption Key (for production use)
# ENCRYPT_KEY=your-encryption-key-here
