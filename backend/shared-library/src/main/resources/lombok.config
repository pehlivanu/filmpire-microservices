# Lombok Configuration for Filmpire Shared Library
# Project-wide Lombok settings

# Add Lombok-generated methods to javadoc
lombok.addLombokGeneratedAnnotation = true

# Enable @Builder to generate toBuilder() method by default
lombok.builder.flagUsage = ALLOW

# Enable @Data to generate toString() with all fields
lombok.toString.includeFieldNames = true

# Enable @EqualsAndHashCode to use all fields
lombok.equalsAndHashCode.callSuper = CALL

# Enable @Getter/@Setter to generate lazy getters
lombok.getter.lazy = true

# Enable @Builder.Default to set default values
lombok.builder.default.flagUsage = ALLOW

# Enable @Singular for collection builders
lombok.singular.flagUsage = ALLOW

# Enable @Log annotations (SLF4J)
lombok.log.flagUsage = ALLOW

# Enable @SuperBuilder for builder pattern with inheritance
lombok.superBuilder.flagUsage = ALLOW

# Enable @With for immutable setters
lombok.with.flagUsage = ALLOW

# Enable @UtilityClass for utility classes
lombok.utilityClass.flagUsage = ALLOW
