# Filmpire Microservices - Docker Compose Environment Variables
# Copy this file to .env and customize the values

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_DB=filmpire
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_PORT=5432

# Multiple databases created on initialization
# Used by User Service and Actor Service

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DATABASE=filmpire
MONGO_PORT=27017

# Used by Movie Service, AI Service, and Media Service

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_PASSWORD=redis123
REDIS_PORT=6379

# Used by API Gateway for rate limiting and session management

# =============================================================================
# MinIO Configuration (Object Storage)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Used by Media Service for storing images, videos, etc.

# =============================================================================
# Management UI Ports (Optional - can be disabled in docker-compose.yml)
# =============================================================================

# Adminer - PostgreSQL Web UI
# Access: http://localhost:9081
# System: PostgreSQL
# Server: postgres
# Username: admin (POSTGRES_USER)
# Password: admin123 (POSTGRES_PASSWORD)
# Database: filmpire (POSTGRES_DB)
# NOTE: Changed from 8081 to avoid conflict with Movie Service (8081)
ADMINER_PORT=9081

# Mongo Express - MongoDB Web UI
# Access: http://localhost:9082
# NOTE: Changed from 8082 to avoid conflict with User Service (8082)
MONGO_EXPRESS_PORT=9082

# Redis Commander - Redis Web UI
# Access: http://localhost:9083
# NOTE: Changed from 8083 to avoid conflict with Actor Service (8083)
REDIS_COMMANDER_PORT=9083

# =============================================================================
# Service Ports (for when services are containerized)
# =============================================================================

# Infrastructure Services
DISCOVERY_SERVICE_PORT=8761
CONFIG_SERVICE_PORT=8888
API_GATEWAY_PORT=8080

# Domain Services
MOVIE_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
ACTOR_SERVICE_PORT=8083
AI_SERVICE_PORT=8084
MEDIA_SERVICE_PORT=8085

# =============================================================================
# Development Notes
# =============================================================================

# 1. Start infrastructure:
#    cd infrastructure/docker
#    docker-compose up -d
#
# 2. Check status:
#    docker-compose ps
#
# 3. View logs:
#    docker-compose logs -f [service-name]
#
# 4. Stop infrastructure:
#    docker-compose down
#
# 5. Stop and remove volumes (CAUTION - deletes data):
#    docker-compose down -v
#
# 6. Access Management UIs:
#    - Adminer (PostgreSQL):    http://localhost:9081
#    - Mongo Express (MongoDB):  http://localhost:9082
#    - Redis Commander (Redis):  http://localhost:9083
#    - MinIO Console:            http://localhost:9001

# =============================================================================
# Connection Strings for Services
# =============================================================================

# PostgreSQL (Spring Boot)
# spring.datasource.url=jdbc:postgresql://localhost:5432/filmpire
# spring.datasource.username=admin
# spring.datasource.password=admin123

# MongoDB (Spring Boot)
# spring.data.mongodb.uri=mongodb://admin:admin123@localhost:27017/filmpire?authSource=admin

# Redis (Spring Boot)
# spring.data.redis.host=localhost
# spring.data.redis.port=6379
# spring.data.redis.password=redis123

# MinIO (Spring Boot with MinIO SDK)
# minio.url=http://localhost:9000
# minio.access-key=minioadmin
# minio.secret-key=minioadmin123

