{
    "info": {
        "_postman_id": "filmpire-movie-service-001",
        "name": "Filmpire Movie Service API",
        "description": "Complete API collection for testing Movie Service through API Gateway with request tracing.\n\nInfrastructure Flow:\n1. Request \u2192 API Gateway (localhost:8080)\n2. Gateway \u2192 Eureka Service Discovery (localhost:8761)\n3. Eureka \u2192 Movie Service (localhost:8081)\n4. Movie Service \u2192 TMDB API (external)\n5. Response with caching (Redis + MongoDB)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Health & Discovery",
            "item": [
                {
                    "name": "Gateway Health",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8080/actuator/health",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "actuator",
                                "health"
                            ]
                        },
                        "description": "Check API Gateway health status"
                    }
                },
                {
                    "name": "Movie Service Health (Direct)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8081/actuator/health",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8081",
                            "path": [
                                "actuator",
                                "health"
                            ]
                        },
                        "description": "Check Movie Service health directly (bypassing gateway)"
                    }
                },
                {
                    "name": "Eureka Dashboard",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8761/",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8761",
                            "path": [
                                ""
                            ]
                        },
                        "description": "View Eureka dashboard to see registered services"
                    }
                }
            ],
            "description": "Health checks and service discovery endpoints"
        },
        {
            "name": "2. Movie Discovery",
            "item": [
                {
                    "name": "Discover Movies (via Gateway)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "X-Request-ID",
                                "value": "{{$randomUUID}}",
                                "description": "Trace ID for request tracking"
                            }
                        ],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/movies/discover?page=1&size=20",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "movies",
                                "discover"
                            ],
                            "query": [
