                {
                    "name": "Get Movie Details (Fight Club)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/movies/550",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "api",
                                "v1",
                                "movies",
                                "550"
                            ]
                        },
                        "description": "Get detailed info for Fight Club (ID: 550)"
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "pm.test(\"Has HATEOAS links\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData._links).to.exist;",
                                    "    pm.expect(jsonData._links.self).to.exist;",
                                    "    pm.expect(jsonData._links.videos).to.exist;",
                                    "    pm.expect(jsonData._links.credits).to.exist;",
                                    "    pm.expect(jsonData._links.similar).to.exist;",
                                    "    pm.expect(jsonData._links.recommendations).to.exist;",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ]
                },
                {
                    "name": "Get Movie Details (Inception)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "http://localhost:8080/api/v1/movies/27205",
                            "protocol": "http",
